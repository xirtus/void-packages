# Template file for 'hyprwire'
pkgname=hyprwire
version=0.3.0
revision=1
build_style=cmake
hostmakedepends="cmake pkgconf"
makedepends="hyprutils libffi-devel pugixml-devel"
short_desc="Fast and consistent wire protocol for IPC"
maintainer="xirtus <xirtus@users.noreply.github.com>"
license="BSD-3-Clause"
homepage="https://github.com/hyprwm/hyprwire"
distfiles="https://github.com/hyprwm/hyprwire/archive/refs/tags/v${version}.tar.gz"
checksum=ba3ff4b82620209d5680ce0e771d0f2c41f78cdb96d5d84fa66e4f0709ca8de6

# This tells XBPS to stop trying to be smart about the scanner
noverifyrdeps=yes

post_patch() {
	  # Dynamically rewrite every instance of the C++23 append_range to the standard insert method
	  find src -type f -name "*.cpp" -exec sed -i 's/\([a-zA-Z0-9_.]*\)\.append_range(\(.*\));/{ auto __val = \2; \1.insert(\1.end(), __val.begin(), __val.end()); }/g' {} +
}

post_install() {
	  # Fix missing version in scanner .pc file to avoid invalid provides in xbps-create
	  vsed -i "s/Version: /Version: ${version}/" ${DESTDIR}/usr/lib/pkgconfig/hyprwire-scanner.pc
	  vlicense LICENSE
}
